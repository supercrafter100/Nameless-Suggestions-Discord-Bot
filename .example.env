# The bot token
TOKEN=

# The server id where the bot is in, leave blank to register commands globally
GUILDID=

# the url where the webserver of the bot is accessible at. For my publicly hosted instance this is "https://suggestions.supercrafter100.com/"
DOMAIN=

# The port the webserver should listen on
PORT=

# Custom name for the /suggest command (optional, defaults to 'suggest')
# SUGGEST_COMMAND_NAME=suggest

# Disable suggesting via Discord (optional, useful when suggestions should only come from website but be synced to discord)
# DISABLE_SUGGESTING=true

# Disable commenting in suggestion threads via Discord (optional, useful when comments should only come from website)
# DISABLE_COMMENTING=true

# Disable like/dislike reactions via Discord buttons (optional, useful when reactions should only be done via website)
# DISABLE_REACTING=true

# Database credentials
DB_PASS=
DB_USER=
DB_NAME=
DB_HOST=
